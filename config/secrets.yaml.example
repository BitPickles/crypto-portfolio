# Crypto Portfolio - API Keys 配置模板
# 复制此文件为 secrets.yaml 并填入真实 API Keys

# DeBank OpenAPI (可选，付费)
debank:
  access_key: "YOUR_DEBANK_ACCESS_KEY"

# Etherscan API V2 (免费版，用于 ETH/L2 链上查询)
etherscan:
  api_key: "YOUR_ETHERSCAN_API_KEY"

# 交易所 API Keys（建议只读权限）
# 格式：每个交易所可配置多个账号
exchanges:
  binance:
    - label: "主账号"
      api_key: "YOUR_BINANCE_API_KEY"
      api_secret: "YOUR_BINANCE_API_SECRET"
  
  bybit:
    - label: "主账号"
      api_key: "YOUR_BYBIT_API_KEY"
      api_secret: "YOUR_BYBIT_API_SECRET"
  
  okx:
    - label: "主账号"
      api_key: "YOUR_OKX_API_KEY"
      api_secret: "YOUR_OKX_API_SECRET"
      passphrase: "YOUR_OKX_PASSPHRASE"
  
  bitget:
    - label: "主账号"
      api_key: "YOUR_BITGET_API_KEY"
      api_secret: "YOUR_BITGET_API_SECRET"
      passphrase: "YOUR_BITGET_PASSPHRASE"
